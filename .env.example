# Copy to .env for local dev (.env is gitignored). Use Stripe TEST keys only.
# Real production values are set as Railway env vars — never commit them.

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # printed by `stripe listen`
# STRIPE_PUBLISHABLE_KEY=pk_test_...      # unused by the hosted-redirect flow; here for completeness

# --- Tips ---
CURRENCY=gbp
MIN_TIP=1                                 # minimum tip, whole currency units
MAX_TIP=500                               # maximum tip, whole currency units

# --- URLs ---
PUBLIC_BASE_URL=http://localhost:8000     # base for success/cancel URLs; prod falls back to RAILWAY_PUBLIC_DOMAIN

# --- Database ---
DATABASE_URL=sqlite:///db.sqlite3         # local default; Railway sets ${{Postgres.DATABASE_URL}} in prod

# --- Ops (optional) ---
RATE_LIMIT=30/minute                      # per-IP cap on /create-checkout-session (slowapi syntax)
# SENTRY_DSN=                             # set to enable Sentry error monitoring (disabled when empty)
