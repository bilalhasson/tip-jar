# Copy to .env for local dev (.env is gitignored). Use Stripe TEST keys only.
# Real production values live in Bitwarden under deploy/tip-jar and as Railway
# env vars — never commit them.

# --- Stripe (added in Stage 1 / Stage 2) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...            # from `stripe listen` locally
# STRIPE_PUBLISHABLE_KEY=pk_test_...         # unused by v1's hosted-redirect flow; here for completeness

# --- App config (added in Stage 1) ---
# CURRENCY=gbp
# PUBLIC_BASE_URL=http://localhost:8000      # falls back to RAILWAY_PUBLIC_DOMAIN in prod
# MIN_TIP=1                                   # min tip in whole currency units
# MAX_TIP=500                                 # max tip in whole currency units

# --- Database (added in Stage 2) ---
# DATABASE_URL=sqlite:///db.sqlite3          # Railway injects Postgres via ${{Postgres.DATABASE_URL}}
